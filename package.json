{
  "name": "opos-enfermeria-test-app",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "node --import tsx --test tests/*.test.ts",
    "build:questions": "node scripts/txt-to-questions-json.js",
    "build:questions:temario": "python scripts/pdf-temario-to-questions.py",
    "build:apk": "npm exec eas -- build -p android --profile preview",
    "build:aab": "npm exec eas -- build -p android --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~51.0.28",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/react": "~18.2.79",
    "eas-cli": "^18.5.0",
    "tsx": "^4.19.3",
    "typescript": "~5.3.3"
  }
}
